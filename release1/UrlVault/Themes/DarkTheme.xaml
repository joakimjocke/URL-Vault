<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- UrlVault Dark Theme — brand: Blueprint Navy depth -->

    <!-- Surfaces -->
    <SolidColorBrush x:Key="AppBackground"              Color="#1E2A38"/>  <!-- Blueprint Navy -->
    <SolidColorBrush x:Key="SurfaceBackground"          Color="#2A2F36"/>  <!-- Scruffy Steel -->
    <SolidColorBrush x:Key="SubSurfaceBackground"       Color="#232B37"/>
    <SolidColorBrush x:Key="HeaderBackground"           Color="#141C26"/>
    <SolidColorBrush x:Key="SubHeaderBackground"        Color="#212C3A"/>
    <SolidColorBrush x:Key="TagBarBackground"           Color="#1A2432"/>

    <!-- Actions -->
    <SolidColorBrush x:Key="PrimaryBrush"               Color="#2D65B0"/>  <!-- Muted Architect Blue for dark surfaces -->
    <SolidColorBrush x:Key="PrimaryHoverBrush"          Color="#3574C4"/>
    <SolidColorBrush x:Key="DangerBrush"                Color="#E53935"/>
    <SolidColorBrush x:Key="DangerHoverBrush"           Color="#EF5350"/>
    <SolidColorBrush x:Key="DisabledBrush"              Color="#4A5568"/>
    <SolidColorBrush x:Key="CancelBrush"                Color="#4A5568"/>
    <SolidColorBrush x:Key="AccentBrush"                Color="#F4A623"/>  <!-- Curiosity Amber -->

    <!-- Text -->
    <SolidColorBrush x:Key="ForegroundPrimary"          Color="#F9F9F9"/>  <!-- Notebook White -->
    <SolidColorBrush x:Key="ForegroundSecondary"        Color="#8B9DB5"/>
    <SolidColorBrush x:Key="ForegroundOnDark"           Color="#F9F9F9"/>
    <SolidColorBrush x:Key="ForegroundSubtle"           Color="#6A7E94"/>
    <SolidColorBrush x:Key="LabelForeground"            Color="#3B80F7"/>

    <!-- Borders & inputs -->
    <SolidColorBrush x:Key="BorderBrush"                Color="#3B4A5C"/>
    <SolidColorBrush x:Key="SearchSurfaceBackground"    Color="#1A2330"/>

    <!-- List -->
    <SolidColorBrush x:Key="ListItemSelectedBackground" Color="#2A4A7F"/>
    <SolidColorBrush x:Key="ListItemSelectedForeground" Color="#F9F9F9"/>
    <SolidColorBrush x:Key="ListItemHoverBackground"    Color="#2D3D52"/>

    <!-- Tree -->
    <SolidColorBrush x:Key="TreeNodeForeground"         Color="#D0D8E4"/>
    <SolidColorBrush x:Key="TreeCountForeground"        Color="#6A7E94"/>

    <!-- SystemColors overrides — forces ComboBox selection box and highlight into theme colors -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"                          Color="#2A2F36"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"                      Color="#F9F9F9"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"                         Color="#2A2F36"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}"                     Color="#F9F9F9"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                       Color="#2A4A7F"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                   Color="#F9F9F9"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"      Color="#232B37"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"  Color="#8B9DB5"/>

</ResourceDictionary>
