<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- UrlVault Light Theme — brand: technical warmth -->

    <!-- Surfaces -->
    <SolidColorBrush x:Key="AppBackground"              Color="#F9F9F9"/>  <!-- Notebook White -->
    <SolidColorBrush x:Key="SurfaceBackground"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SubSurfaceBackground"       Color="#F4F6FA"/>
    <SolidColorBrush x:Key="HeaderBackground"           Color="#2A2F36"/>  <!-- Scruffy Steel -->
    <SolidColorBrush x:Key="SubHeaderBackground"        Color="#E4E4E4"/>  <!-- Warm Grey -->
    <SolidColorBrush x:Key="TagBarBackground"           Color="#EEEFF2"/>

    <!-- Actions -->
    <SolidColorBrush x:Key="PrimaryBrush"               Color="#3B80F7"/>  <!-- Architect Blue -->
    <SolidColorBrush x:Key="PrimaryHoverBrush"          Color="#2A6EE8"/>
    <SolidColorBrush x:Key="DangerBrush"                Color="#E53935"/>
    <SolidColorBrush x:Key="DangerHoverBrush"           Color="#EF5350"/>
    <SolidColorBrush x:Key="DisabledBrush"              Color="#AAAAAA"/>
    <SolidColorBrush x:Key="CancelBrush"                Color="#757575"/>
    <SolidColorBrush x:Key="AccentBrush"                Color="#F4A623"/>  <!-- Curiosity Amber -->

    <!-- Text -->
    <SolidColorBrush x:Key="ForegroundPrimary"          Color="#2A2F36"/>
    <SolidColorBrush x:Key="ForegroundSecondary"        Color="#607884"/>
    <SolidColorBrush x:Key="ForegroundOnDark"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ForegroundSubtle"           Color="#9AABB8"/>
    <SolidColorBrush x:Key="LabelForeground"            Color="#3B80F7"/>

    <!-- Borders & inputs -->
    <SolidColorBrush x:Key="BorderBrush"                Color="#D0D5DD"/>
    <SolidColorBrush x:Key="SearchSurfaceBackground"    Color="#FFFFFF"/>

    <!-- List -->
    <SolidColorBrush x:Key="ListItemSelectedBackground" Color="#D6E6FF"/>
    <SolidColorBrush x:Key="ListItemSelectedForeground" Color="#1E2A38"/>
    <SolidColorBrush x:Key="ListItemHoverBackground"    Color="#EDF4FF"/>

    <!-- Tree -->
    <SolidColorBrush x:Key="TreeNodeForeground"         Color="#2A2F36"/>
    <SolidColorBrush x:Key="TreeCountForeground"        Color="#9AABB8"/>

    <!-- SystemColors overrides — forces ComboBox selection box and highlight into theme colors -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"                          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"                      Color="#2A2F36"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"                         Color="#F9F9F9"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}"                     Color="#2A2F36"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                       Color="#D6E6FF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                   Color="#1E2A38"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"      Color="#E4E4E4"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"  Color="#2A2F36"/>

</ResourceDictionary>
